        </div>
        <div class="flex flex-col items-center justify-between">
          <p class="text-heading5 text-white my-8">Reset password</p>
          
          <form action="/login" class="space-y-6 mb-8 text-white" method="POST">
            <div class="w-[432px]">
              <input type="password" name="newpassword" id="newpassword" placeholder="New Password" class="w-full form-control text-body-small-medium px-6 py-4 text-white-300 bg-black border-white-100 border-2 rounded-full bg-gradient-to-br from-black to-white-100" required>
            </div>
            <div class="w-[432px]">
                <input type="password" name="cnfpassword" id="cnfpassword" placeholder="Confirm Password" class="w-full form-control text-body-small-medium px-6 py-4 text-white-300 bg-black border-white-100 border-2 rounded-full bg-gradient-to-br from-black to-white-100" required>
              </div>
            <button type="submit" class="w-full form-control text-body-xsmall-semibold px-6 py-4 text-white bg-brand-700 border-white-100 border-2 rounded-full ">Reset</button>
          </form>
        </div>
      </div>
    </div>
  </section>
