<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head', { title: 'SharedStars Home' }) %>
  <body class="bg-black">
    <!-- Header (Navigation & Language Selector) -->
    <%- include('partials/header') %>

    <!-- Hero Section -->
   
    <section id="hero" class="relative min-h-screen flex items-start justify-center text-center pt-24 z-40">
      <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
        <source src="/public/videos/academy10.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
  
      <div class="absolute inset-0 w-full h-full bg-black pointer-events-none bg-opacity-75 z-20"></div>

      <div class="relative flex flex-col mt-28 items-center justify-start max-w-5xl px-4 z-20">
        <h1 class="hero-text font-aeonik text-heading1 text-white px-20 mb-6">World's Largest AI- Powered Space Training Platform</h1>
        <p data-i18n="hero.subtitle" class="text-body-medium-medium max-w-2xl text-white mb-8">
          In 36 months, humanity splits into two groups: Those who have prepared for space and those who watch from Earth.
        </p>
        <div class="w-full space-x-4 text-body-2xsmall-semibold">
          <a data-i18n="hero.beginTraining" href="/signup" class="bg-black text-white px-6 py-3 z-30 rounded-full hover:bg-blue-700 shadow-[inset_2px_2px_5px_rgba(255,255,255,0.2),_inset_-2px_-2px_5px_rgba(0,0,0,0.2),_2px_2px_6px_rgba(0,0,0,0.3)] transition">Start Training Now</a>
          <a data-i18n="hero.yourCountdown" href="/signup" class="bg-black text-white px-6 py-3 rounded-full hover:bg-blue-700 shadow-[inset_2px_2px_5px_rgba(255,255,255,0.2),_inset_-2px_-2px_5px_rgba(0,0,0,0.2),_2px_2px_6px_rgba(0,0,0,0.3)] transition">See Your Countdown to Space</a>
          <a data-i18n="hero.membershipPlans" href="/signup" class="bg-black text-white px-6 py-3 rounded-full hover:bg-blue-700 shadow-[inset_2px_2px_5px_rgba(255,255,255,0.2),_inset_-2px_-2px_5px_rgba(0,0,0,0.2),_2px_2px_6px_rgba(0,0,0,0.3)] transition">Explore Membership Plans</a>
        </div>
      </div>
    </section>

    <!-- Progress Section -->
    <section class="min-h-screen px-[120px] py-[120px]">
        <div class="bg-black text-white">
            <!-- Progress Label -->
            <span class="text-brand-600 bg-black px-3 py-1 text-body-2xsmall-semibold rounded-lg shadow-[inset_2px_2px_5px_rgba(255,255,255,0.2),_inset_-2px_-2px_5px_rgba(0,0,0,0.2),_2px_2px_6px_rgba(0,0,0,0.3)]">
                Progress
            </span>
    
            <div class="flex justify-between">
              <div class="w-1/2">
                <h2 class="text-heading2 font-aeonik mt-5">Your path to space</h2>
                <p class="text-white-800 mt-5 pr-36">
                  In 36 months, humanity splits into two groups: Those who prepare for space and those who watch from
                  Earth.
                </p>
              </div>
              <div class="flex items-end">
                <button class="px-6 py-3 text-white bg-black text-body-2xsmall-semibold rounded-full 
                shadow-[inset_1px_1px_2px_rgba(255,255,255,0.4)]">
                  Subscribe now →
                </button>
              </div>
            </div>    
    
            <!-- Countdown Timer -->
            <div class="grid grid-cols-7 gap-6 text-center mt-14">
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-heading1 font-aeonik">13</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>
                    <p class="text-body-base">Years</p>
                </div>
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-6xl font-bold">08</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>         
                    <p class=" text-[16px]">Months</p>
                </div>
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-6xl font-bold">02</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>
                    <p class=" text-[16px]">Weeks</p>
                </div>
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-6xl font-bold">17</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>
                    <p class=" text-[16px]">Days</p>
                </div>
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-6xl font-bold">06</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>
                    <p class=" text-[16px]">Hours</p>
                </div>
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-6xl font-bold">23</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>
                    <p class=" text-[16px]">Minutes</p>
                </div>
                <div class="flex flex-col p-4 bg-black rounded-lg gap-6 h-[178px] justify-center shadow-[inset_1px_1px_5px_rgba(255,255,255,0.4)]">
                    <span class="text-6xl font-bold">45</span>
                    <span class="relative h-[2px] w-full before:content-[''] before:absolute before:left-0 before:right-0 before:top-0 
                    before:h-full before:bg-gradient-to-r before:from-transparent 
                    before:via-[#0060FF] before:to-transparent"></span>
                    <p class=" text-[16px]">Seconds</p>
                </div>
            </div>
    
            <span class="flex w-full mt-14 border-b border-white-200"></span>
    
            <div class="flex items-center justify-start bg-black gap-8 mt-14">
              <!-- Video Container -->
              <div class=" w-[160px] h-[90px] rounded-lg p-1 bg-black border-2 border-white-200 overflow-hidden">
                <!-- Video Element -->
                  <video id="videoPlayer" class="rounded-md">
                    <source src="/public/videos//space1.mp4" type="video/mp4">
                      Your browser does not support the video tag.
                  </video>
              </div>
            
              <div class="flex flex-col items-start justify-between space-y-6">
                  <p class="text-body-base-semibold max-w-64 tetx-white ">Learn how you can accelerate their journey?</p>
                  <a href="https://example.com" class="text-brand-700 hover:underline text-body-2xsmall-semibold font-medium">
                      Learn More →
                  </a>
              </div>
            </div>
        </div>
    
      </section>
    <!-- Training Dashboard (Hidden by Default) -->
    <section id="training-dashboard" class="py-16 bg-gray-900 hidden">
      <div class="container mx-auto px-4">
        <div class="progress-tracker mb-8">
          <div class="progress-bar"></div>
          <div id="progressDisplay">Progress: 0%</div>
        </div>
        <div class="current-module bg-black/30 p-6 rounded-xl">
          <h3 class="text-2xl font-bold text-white mb-4">Current Module</h3>
          <div id="moduleContent"></div>
        </div>
      </div>
    </section>

    <!-- Social Media Section -->
    <section class="social-media-section bg-gray-900 py-6 text-white text-center">
      <h2 class="text-2xl font-bold mb-4">Follow Us</h2>
      <div class="flex justify-center gap-6">
        <a href="#" id="twitter-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="Twitter">🐦 Twitter</a>
        <a href="#" id="facebook-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="Facebook">📘 Facebook</a>
        <a href="#" id="instagram-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="Instagram">📷 Instagram</a>
        <a href="#" id="linkedin-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="LinkedIn">💼 LinkedIn</a>
        <a href="#" id="telegram-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="Telegram">📢 Telegram</a>
        <a href="#" id="tiktok-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="TikTok">🎵 TikTok</a>
        <a href="#" id="youtube-link" target="_blank" class="hover:text-blue-400 transition-colors" aria-label="YouTube">▶️ YouTube</a>
      </div>
    </section>

    <!-- Footer -->
    <%- include('partials/footer') %>

    <!-- Training Module Scripts -->
    <script type="module">
      import { initializeTrainingModules } from '/js/modules/training/index.js';

      document.addEventListener('DOMContentLoaded', () => {
        initializeTrainingModules({
          modules: ['physical', 'technical', 'simulation'],
          endpoints: {
            physical: '/api/training/modules/physical',
            technical: '/api/training/modules/technical',
            simulation: '/api/training/modules/simulation'
          }
        });
        const currentLang = localStorage.getItem('preferredLanguage') || 'en';
        document.documentElement.setAttribute('lang', currentLang);
      });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script type="module" src="/js/modules/core/index.js"></script>
  </body>
</html>
